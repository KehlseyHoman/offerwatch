# ─────────────────────────────────────────────────────────────────────────────
# Offerwatch API — local dev environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored and must NEVER be committed.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL / Supabase (Supavisor pooler — transaction mode, port 6543)
# Get from: Supabase Dashboard → Project Settings → Database → Connection Pooling
# Append sslmode=require&prepareThreshold=0 — required for Supavisor.
DB_URL=jdbc:postgresql://aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require&prepareThreshold=0
DB_USERNAME=postgres.YOUR_PROJECT_REF
DB_PASSWORD=your-supabase-db-password

# JWT secret — generate with: openssl rand -hex 64
JWT_SECRET=replace-with-a-long-random-secret

# Google OAuth — Client ID from Google Cloud Console (Credentials page)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Optional overrides (defaults shown)
# PORT=8080
# JWT_EXPIRATION_MS=86400000
# CORS_ALLOWED_ORIGINS=http://localhost:4200
